#!/usr/bin/env bash
# annotateyaml — prepend a `yaml-language-server: $schema=...` modeline
# to each document in one or more multi-doc Kubernetes YAML files so
# VS Code's YAML extension validates them.
#
# Schemas resolve from a local directory first (default: ./schemas
# next to this script), then fall back to datreeio's CRDs-catalog.
# An existing schema modeline on a document is replaced rather than
# duplicated.
#
# Usage: annotateyaml [--schemas-dir DIR] FILE [FILE...]
#
# Requires: yq (v4), curl, perl.

set -euo pipefail

BASE_URL="https://datreeio.github.io/CRDs-catalog/"
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/datree_crds_catalog"
INDEX_FILE="$CACHE_DIR/index.yaml"
INDEX_MAX_AGE_DAYS=7

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DEFAULT_LOCAL_SCHEMAS_DIR="$SCRIPT_DIR/schemas"

die() { printf 'annotateyaml: %s\n' "$*" >&2; exit 1; }

for cmd in yq curl perl; do
  command -v "$cmd" >/dev/null || die "$cmd is required"
done

schemas_dir="$DEFAULT_LOCAL_SCHEMAS_DIR"
files=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --schemas-dir)   schemas_dir="$2"; shift 2 ;;
    --schemas-dir=*) schemas_dir="${1#*=}"; shift ;;
    -h|--help)
      sed -n '2,12p' "$0" | sed 's/^# \?//'
      exit 0 ;;
    --) shift; files+=("$@"); break ;;
    -*) die "unknown option: $1" ;;
    *)  files+=("$1"); shift ;;
  esac
done

[[ ${#files[@]} -gt 0 ]] || die "no input files"

# Refresh the cached datreeio index if missing or older than the TTL.
download_index() {
  mkdir -p "$CACHE_DIR"
  if [[ -f "$INDEX_FILE" ]]; then
    local mtime now age
    mtime=$(stat -f %m "$INDEX_FILE" 2>/dev/null || stat -c %Y "$INDEX_FILE")
    now=$(date +%s)
    age=$(( (now - mtime) / 86400 ))
    (( age < INDEX_MAX_AGE_DAYS )) && return
  fi
  printf 'Downloading %sindex.yaml...\n' "$BASE_URL" >&2
  curl -fsSL -o "$INDEX_FILE" "${BASE_URL}index.yaml"
}

# Resolve a schema URL (or relative local path) for an apiVersion+kind.
# Args: <api_version> <kind> <yaml_dir>
# Echoes the URL/path on stdout, or nothing if no match exists.
find_schema() {
  local api_version="$1" kind="$2" yaml_dir="$3"
  local av_lc kind_lc group version
  av_lc=$(printf '%s' "$api_version" | tr '[:upper:]' '[:lower:]')
  kind_lc=$(printf '%s' "$kind"        | tr '[:upper:]' '[:lower:]')
  if [[ "$av_lc" == */* ]]; then
    group="${av_lc%/*}"
    version="${av_lc#*/}"
  else
    group="$av_lc"
    version=""
  fi

  # Local schemas directory takes precedence over the online catalog.
  if [[ -d "$schemas_dir" ]]; then
    local local_path="$schemas_dir/$group/${kind_lc}_${version}.json"
    if [[ -f "$local_path" ]]; then
      # BSD realpath has no --relative-to; perl's File::Spec is
      # available everywhere bash is and handles cross-platform paths
      # without dragging in coreutils.
      perl -MFile::Spec -e 'print File::Spec->abs2rel($ARGV[0], $ARGV[1])' \
        "$local_path" "$yaml_dir"
      return
    fi
  fi

  # Online catalog: walk the index, match on (apiVersion, kind), grab
  # the filename. The index is grouped by API group at the top level,
  # so we flatten with `.[] | .[]` first.
  local filename
  filename=$(AV="$av_lc" K="$kind_lc" yq '
    [.[] | .[]
      | select((.apiVersion | downcase) == strenv(AV)
            and (.kind       | downcase) == strenv(K))
      | .filename] | .[0] // ""
  ' "$INDEX_FILE")
  if [[ -n "$filename" && "$filename" != "null" ]]; then
    printf '%s%s' "$BASE_URL" "$filename"
  fi
  # Always return success — an empty stdout signals "no schema" to
  # the caller. Returning non-zero from a function called inside a
  # command substitution would trip `set -e` and silently abort.
  return 0
}

# Replace (or insert) the schema modeline on a single document.
#
# Two yq quirks make this expression less obvious than it should be:
#
#   1. The "head comment" of a multi-doc YAML *document* is actually
#      stored on the head_comment of the FIRST KEY of the doc's root
#      mapping — not on the document node. Reading or writing
#      `headComment` on the document itself returns/persists nothing.
#      We resolve the first key with `keys | .[0]` so we don't bake in
#      a `apiVersion` assumption.
#
#   2. `headComment` evaluated inside `with(select(...); ...)` returns
#      the matched node, not its head comment string. To strip an
#      existing schema modeline before re-adding one we must capture
#      the comment in a variable BEFORE the assignment.
#
# Args: <doc_index> <file> <schema_url>
annotate_doc() {
  local di="$1" file="$2" url="$3"
  DI="$di" URL="$url" yq -i '
    (select(documentIndex == (env(DI) | tonumber)) | keys | .[0]) as $k |
    (select(documentIndex == (env(DI) | tonumber)) | .[$k] | key | headComment) as $hc |
    (select(documentIndex == (env(DI) | tonumber)) | .[$k] | key) head_comment = (
      [
        "yaml-language-server: $schema=" + strenv(URL),
        ($hc
          | split("\n")
          | map(select(test("yaml-language-server:.*schema") | not))
          | join("\n"))
      ]
      | map(select(. != ""))
      | join("\n")
    )
  ' "$file"
}

annotate_file() {
  local file="$1"
  local yaml_dir
  yaml_dir=$(cd "$(dirname "$file")" && pwd)

  # eval-all collects every input document so we can emit one
  # pipe-delimited line per doc — easier to parse than yq's default
  # multi-doc scalar output, which interleaves `---` separators.
  local meta
  meta=$(yq ea '
    [. | (documentIndex | tostring)
       + "|" + (.apiVersion // "")
       + "|" + (.kind // "")]
    | .[]
  ' "$file")

  local di api_version kind url line
  while IFS='|' read -r di api_version kind; do
    [[ -z "$api_version" || -z "$kind" ]] && continue
    url=$(find_schema "$api_version" "$kind" "$yaml_dir")
    if [[ -z "$url" ]]; then
      printf 'annotateyaml: no schema for %s %s in %s (doc %s)\n' \
        "$api_version" "$kind" "$file" "$di" >&2
      continue
    fi
    annotate_doc "$di" "$file" "$url"
  done <<< "$meta"
}

download_index
for f in "${files[@]}"; do
  [[ -f "$f" ]] || die "not a file: $f"
  annotate_file "$f"
done
