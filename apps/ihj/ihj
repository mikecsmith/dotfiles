#!/usr/bin/env python3
import webbrowser

from config.bootstrap import initialize_app
from jira.client import JiraClient

from commands.upsert import execute_upsert
from commands.comment import execute_comment
from commands.assign import execute_assign
from commands.branch import execute_branch
from commands.transition import execute_transition
from commands.export import execute_export
from commands.tui import execute_tui
from commands.list import execute_list


def main():
    # 1. Gather all configuration, args, and environment context
    ctx = initialize_app()

    args = ctx["args"]
    cfg = ctx["cfg"]

    # 2. Spin up the Domain Client
    client = JiraClient(cfg.get("server"), ctx["token"])

    # 3. Route the command
    cmd = args.command or "tui"

    if cmd == "create":
        execute_upsert(
            args, ctx["cache_dir"], client, cfg, ctx["use_toast"], is_edit=False
        )

    elif cmd == "edit":
        execute_upsert(
            args, ctx["cache_dir"], client, cfg, ctx["use_toast"], is_edit=True
        )

    elif cmd == "comment":
        execute_comment(args.issue_key, client, cfg, ctx["use_toast"], args.dry_run)

    elif cmd == "assign":
        execute_assign(args.issue_key, ctx["cache_dir"], client, ctx["use_toast"])

    elif cmd == "branch":
        execute_branch(
            args.issue_key,
            getattr(args, "board", None),
            ctx["cache_dir"],
            ctx["use_toast"],
        )

    elif cmd == "transition":
        execute_transition(args.issue_key, client, cfg, ctx["use_toast"])

    elif cmd == "open":
        webbrowser.open(f"{client.server}/browse/{args.issue_key}")

    elif cmd == "export":
        board = getattr(args, "board", None) or cfg.get("default_board", "ci")
        mode = getattr(args, "mode", None) or "active"
        execute_export(board, mode, client, cfg)

    elif cmd == "list":
        board = getattr(args, "board", None) or cfg.get("default_board", "ci")
        mode = getattr(args, "mode", None) or "active"
        execute_list(board, mode, ctx["cache_dir"], client, cfg)

    elif cmd == "tui":
        board = getattr(args, "board", None) or cfg.get("default_board", "ci")
        mode = getattr(args, "mode", None) or "active"
        execute_tui(board, mode, ctx["cache_dir"], ctx["executable"], client, cfg)


if __name__ == "__main__":
    main()
